<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JobTracker - ระบบติดตามการสมัครงาน</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- FIX 1: เปลี่ยนจาก <style src="..."> เป็น <script src="..."> ที่ถูกต้อง -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        :root {
            --bg-color: #FFF9FE;
            --text-dark: #5D546C;
            --text-light: #A594B0;
            --primary-color: #FF85D1; /* Hot Pink Pastel */
            --secondary-color: #FFE5F4;
            --white: #FFFFFF;
            --accent-color: #FFD56B; /* Sunny Yellow */
            --success: #98EECC; /* Mint Green */
            --warning: #FFD966;
            --error: #FFADAD;
            --info: #A0C4FF; /* Sky Blue */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Prompt', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #FFF0F6 0%, #E6FBFF 100%);
            color: var(--text-dark);
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* --- Decorative Background Shapes --- */
        .bubble {
            position: fixed;
            border-radius: 50%;
            filter: blur(40px);
            z-index: -1;
            opacity: 0.5;
            animation: float 10s infinite alternate ease-in-out;
        }
        @keyframes float {
            from { transform: translate(0, 0); }
            to { transform: translate(20px, 40px); }
        }

        .container {
            width: 100%;
            max-width: 900px;
            position: relative;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        h1 {
            background: linear-gradient(45deg, #FF85D1, #A0C4FF);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            font-size: 2.5rem;
            margin-bottom: 10px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            padding: 30px;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.04);
            margin-bottom: 30px;
            border: 2px solid rgba(255, 255, 255, 0.6);
        }

        .form-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: end;
        }

        @media (max-width: 768px) {
            .form-grid { grid-template-columns: 1fr; }
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1 1 200px;
        }

        label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-light);
        }

        input, select {
            padding: 14px;
            border: 2px solid #F0F0F0;
            border-radius: 15px;
            outline: none;
            font-size: 1rem;
            transition: 0.3s;
            background: var(--white);
        }

        input:focus, select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(255, 133, 209, 0.15);
        }

        button {
            padding: 12px 25px;
            border: none;
            border-radius: 18px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-add {
            background: linear-gradient(45deg, #FF85D1, #FFD56B);
            color: white;
            box-shadow: 0 8px 20px rgba(255, 133, 209, 0.3);
            height: 52px;
        }

        .btn-add:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(255, 183, 178, 0.4);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
            width: 100%;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            padding: 20px;
            border-radius: 25px;
            text-align: center;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.3);
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
        }
        .stat-card.interview-today {
            border: 2px solid var(--accent-color);
            box-shadow: 0 0 20px rgba(255, 213, 107, 0.4);
            background: rgba(255, 255, 255, 0.5);
            animation: pulse-glow 2s infinite;
        }
        .stat-card:hover { transform: translateY(-8px) scale(1.05); background: var(--white); box-shadow: 0 15px 30px rgba(0,0,0,0.08); }
        .stat-card h2 { font-size: 1.8rem; margin-bottom: 5px; }
        .stat-card p { font-size: 0.85rem; color: var(--text-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }

        /* --- Progress Visualization --- */
        .progress-container {
            width: 100%;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 15px;
            height: 25px;
            margin-bottom: 30px;
            display: flex;
            overflow: hidden;
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.05);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .progress-segment {
            height: 100%;
            transition: width 0.5s ease-in-out;
        }

        .progress-label {
            font-size: 0.9rem;
            color: var(--text-light);
            margin-bottom: 10px;
            font-weight: 600;
        }

        .alert-banner {
            width: 100%;
            background-color: var(--warning);
            color: var(--text-dark);
            padding: 15px;
            border-radius: 18px;
            margin-bottom: 25px;
            text-align: center;
            font-weight: 600;
            box-shadow: 0 10px 20px rgba(233, 196, 106, 0.2);
            display: none;
        }

        .job-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .job-item {
            background: rgba(255, 255, 255, 0.8);
            padding: 25px;
            border-radius: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
            border-left: 6px solid var(--secondary-color);
            transition: all 0.3s ease;
            border: 2px solid rgba(255, 255, 255, 0.6);
            position: relative;
            overflow: hidden;
        }
        .job-item:hover { transform: scale(1.01); background: var(--white); box-shadow: 0 12px 25px rgba(0,0,0,0.05); }
        
        .job-item.interview-near {
            box-shadow: 0 0 15px rgba(255, 213, 107, 0.2);
            border-right: 4px solid var(--accent-color);
        }

        @keyframes pulse-glow {
            0% { box-shadow: 0 0 10px rgba(255, 213, 107, 0.3); }
            50% { box-shadow: 0 0 25px rgba(255, 213, 107, 0.6); }
            100% { box-shadow: 0 0 10px rgba(255, 213, 107, 0.3); }
        }

        /* --- Modal Styles --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            opacity: 0;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
            opacity: 1;
        }

        .modal-content {
            background: var(--white);
            width: 90%;
            max-width: 550px;
            padding: 35px;
            border-radius: 40px;
            position: relative;
            transform: scale(0.8) translateY(20px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 30px 60px rgba(255, 133, 209, 0.15);
            border: 6px solid var(--secondary-color);
        }

        .modal-overlay.active .modal-content {
            transform: scale(1) translateY(0);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .close-modal {
            background: var(--secondary-color);
            color: var(--primary-color);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            font-size: 1.5rem;
            transition: 0.3s;
        }
        .close-modal:hover { background: var(--primary-color); color: white; transform: rotate(90deg); }

        /* --- Wow Animation for new items --- */
        @keyframes popAndBounce {
            0% { transform: scale(0.5) translateY(30px) rotate(-2deg); opacity: 0; filter: brightness(2); }
            60% { transform: scale(1.08) translateY(-10px) rotate(1deg); }
            80% { transform: scale(0.98) translateY(2px); }
            100% { transform: scale(1) translateY(0) rotate(0); opacity: 1; filter: brightness(1); }
        }

        .job-item-new {
            animation: popAndBounce 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            border-color: var(--primary-color) !important;
            box-shadow: 0 0 30px rgba(255, 133, 209, 0.3) !important;
            z-index: 10;
        }

        .job-info h3 { font-size: 1.2rem; margin-bottom: 4px; color: var(--text-dark); }
        .job-info p { font-size: 0.9rem; color: var(--text-light); }

        .status-badge {
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            text-align: center;
            border: none;
            cursor: pointer;
        }

        .status-applied { background-color: var(--info); color: var(--text-dark); }
        .status-interview { background-color: var(--warning); color: var(--text-dark); }
        .status-hired { background-color: var(--success); color: var(--text-dark); }
        .status-rejected { background-color: var(--error); color: var(--text-dark); }
        .status-pending { background-color: var(--secondary-color); color: var(--text-dark); }

        .actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-delete {
            background: none;
            color: var(--error);
            font-size: 1.2rem;
            padding: 5px;
            opacity: 0.5;
        }
        .btn-delete:hover { opacity: 1; transform: scale(1.1); }

        .btn-pin {
            background: none;
            font-size: 1.1rem;
            padding: 5px;
            cursor: pointer;
            transition: 0.3s;
            opacity: 0.4;
        }
        .btn-pin.active { opacity: 1; transform: scale(1.2); filter: drop-shadow(0 0 5px rgba(255, 183, 178, 0.5)); }

        .search-filter-container {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
            width: 100%;
        }
        @media (max-width: 600px) {
            .search-filter-container { grid-template-columns: 1fr; }
        }

        .btn-edit {
            background: none;
            color: var(--primary-color);
            font-size: 1.1rem;
            padding: 5px;
            opacity: 0.6;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-edit:hover { opacity: 1; transform: scale(1.1); }

        .btn-clear-all {
            background: none;
            color: var(--error);
            border: 1px solid var(--error);
            font-size: 0.8rem;
            padding: 5px 12px;
            border-radius: 8px;
            opacity: 0.6;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-clear-all:hover { opacity: 1; background: var(--error); color: white; }

        .btn-export {
            background: var(--white);
            color: var(--primary-color);
            border: 1px solid var(--primary-color);
            font-size: 0.8rem;
            padding: 5px 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-export:hover { background: var(--primary-color); color: white; }

        .note-display {
            margin-top: 12px;
            font-size: 0.85rem;
            color: var(--text-dark);
            background: rgba(255, 255, 255, 0.5);
            padding: 10px;
            border-radius: 12px;
            border-left: 4px solid var(--accent-color);
            white-space: pre-wrap;
        }
    </style>
</head>
<body>
    <!-- Decorative Background Elements -->
    <div class="bubble" style="width: 300px; height: 300px; background: #FFD56B; top: -100px; right: -50px;"></div>
    <div class="bubble" style="width: 250px; height: 250px; background: #A0C4FF; bottom: -50px; left: -50px; animation-delay: 2s;"></div>
    <div class="bubble" style="width: 150px; height: 150px; background: #FF85D1; top: 40%; left: -80px; animation-delay: 4s;"></div>

    <div class="container">
        <header>
            <h1>Job Application Tracker</h1>
            <p>ติดตามสถานะการสมัครงานของคุณอย่างเป็นระเบียบ</p>
        </header>

        <div id="interview-alert" class="alert-banner"></div>

        <div class="stats-grid">
            <div class="stat-card" onclick="setFilter('pending')" style="border-bottom: 6px solid var(--secondary-color);">
                <h2 id="count-pending">0</h2>
                <p>📝 เตรียมตัว</p>
            </div>
            <div class="stat-card" onclick="setFilter('applied')" style="border-bottom: 6px solid var(--info);">
                <h2 id="count-applied">0</h2>
                <p>🚀 ส่งแล้ว</p>
            </div>
            <div class="stat-card" onclick="setFilter('interview')" style="border-bottom: 6px solid var(--warning);">
                <h2 id="count-interview">0</h2>
                <p>🤝 นัดหมาย</p>
            </div>
            <div class="stat-card" onclick="setFilter('hired')" style="border-bottom: 6px solid var(--success);">
                <h2 id="count-hired">0</h2>
                <p>✨ สำเร็จ!</p>
            </div>
            <div class="stat-card" onclick="setFilter('rejected')" style="border-bottom: 6px solid var(--error);">
                <h2 id="count-rejected">0</h2>
                <p>💔 ไม่ผ่าน</p>
            </div>
        </div>

        <!-- Progress Visualization -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <div class="progress-label" style="margin-bottom: 0;">ภาพรวมสถานะการสมัครงาน</div>
            <div style="display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end;">
                <button class="btn-export" onclick="exportToCSV()">📥 ส่งออก Excel (CSV)</button>
                <button class="btn-export" onclick="backupToJSON()">💾 สำรอง JSON</button>
                <button class="btn-export" onclick="document.getElementById('import-input').click()">📂 กู้คืน JSON</button>
                <input type="file" id="import-input" style="display: none;" accept=".json" onchange="importFromJSON(event)">
                <button class="btn-clear-all" onclick="clearAllJobs()">ล้างข้อมูลทั้งหมด</button>
            </div>
        </div>
        <div class="progress-container" id="progress-bar">
            <div class="progress-segment" id="bar-pending" style="background-color: var(--secondary-color);"></div>
            <div class="progress-segment" id="bar-applied" style="background-color: var(--info);"></div>
            <div class="progress-segment" id="bar-interview" style="background-color: var(--warning);"></div>
            <div class="progress-segment" id="bar-hired" style="background-color: var(--success);"></div>
            <div class="progress-segment" id="bar-rejected" style="background-color: var(--error);"></div>
        </div>

        <!-- Edit Modal Structure -->
        <div id="edit-modal" class="modal-overlay" onclick="closeEditModal()">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <h2 style="color: var(--primary-color);">แก้ไขข้อมูลงาน ✨</h2>
                    <div class="close-modal" onclick="closeEditModal()">&times;</div>
                </div>
                <div class="form-grid" style="grid-template-columns: 1fr; gap: 20px;">
                    <div class="input-group">
                        <label>ชื่อบริษัท</label>
                        <input type="text" id="edit-company-name">
                    </div>
                    <div class="input-group">
                        <label>วันที่สมัคร</label>
                        <input type="date" id="edit-applied-date">
                    </div>
                    <div class="input-group">
                        <label>ตำแหน่งงาน</label>
                        <input type="text" id="edit-job-role">
                    </div>
                    <div class="input-group">
                        <label>สถานที่บริษัท</label>
                        <input type="text" id="edit-job-location" placeholder="เช่น อโศก, กรุงเทพฯ">
                    </div>
                    <div class="input-group">
                        <label>ประเภทงาน</label>
                        <select id="edit-work-type">
                            <option value="On-site">On-site</option>
                            <option value="Remote">Remote</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="Freelance">Freelance</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>ลิงก์ประกาศงาน (URL)</label>
                        <input type="url" id="edit-job-url" placeholder="https://...">
                    </div>
                    <div class="input-group">
                        <label>ช่องทางสมัคร</label>
                        <select id="edit-job-channel">
                            <option value="Direct">สมัครโดยตรง</option>
                            <option value="LinkedIn">LinkedIn</option>
                            <option value="JobThai">JobThai</option>
                            <option value="JobsDB">JobsDB</option>
                            <option value="JobGun">JobGun</option>
                            <option value="Other">อื่นๆ</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>สถานะ</label>
                        <select id="edit-job-status">
                            <option value="pending">กำลังเตรียมตัว</option>
                            <option value="applied">ส่งใบสมัครแล้ว</option>
                            <option value="interview">รอสัมภาษณ์ / สัมภาษณ์</option>
                            <option value="hired">ได้งานแล้ว ✨</option>
                            <option value="rejected">ไม่ผ่าน</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>วันที่สัมภาษณ์ (ถ้ามี)</label>
                        <input type="date" id="edit-interview-date">
                    </div>
                    <div class="input-group">
                        <label>บันทึกเพิ่มเติม</label>
                        <textarea id="edit-job-notes" style="padding: 12px; border: 1.5px solid var(--secondary-color); border-radius: 12px; font-family: 'Prompt'; resize: vertical; min-height: 80px;"></textarea>
                    </div>
                    <button class="btn-add" style="width: 100%;" onclick="saveEdit()">บันทึกการแก้ไข</button>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="form-grid">
                <div class="input-group">
                    <label>ชื่อบริษัท</label>
                    <input type="text" id="company-name" placeholder="เช่น GMM Grammy">
                </div>
                <div class="input-group">
                    <label>วันที่สมัคร</label>
                    <input type="date" id="applied-date">
                </div>
                <div class="input-group">
                    <label>ตำแหน่งงาน</label>
                    <input type="text" id="job-role" placeholder="เช่น Graphic Designer">
                </div>
                <div class="input-group">
                    <label>สถานที่บริษัท</label>
                    <input type="text" id="job-location" placeholder="เช่น อโศก, กรุงเทพฯ">
                </div>
                <div class="input-group">
                    <label>ประเภทงาน</label>
                    <select id="job-work-type">
                        <option value="On-site">On-site</option>
                        <option value="Remote">Remote</option>
                        <option value="Hybrid">Hybrid</option>
                        <option value="Freelance">Freelance</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>ลิงก์ประกาศงาน (URL)</label>
                    <input type="url" id="job-url" placeholder="https://...">
                </div>
                <div class="input-group">
                    <label>ช่องทางสมัคร</label>
                    <select id="job-channel">
                        <option value="Direct">สมัครโดยตรง</option>
                        <option value="LinkedIn">LinkedIn</option>
                        <option value="JobThai">JobThai</option>
                        <option value="JobsDB">JobsDB</option>
                        <option value="JobGun">JobGun</option>
                        <option value="Other">อื่นๆ</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>สถานะ</label>
                    <select id="job-status">
                        <option value="pending">กำลังเตรียมตัว</option>
                        <option value="applied">ส่งใบสมัครแล้ว</option>
                        <option value="interview">รอสัมภาษณ์ / สัมภาษณ์</option>
                        <option value="hired">ได้งานแล้ว ✨</option>
                        <option value="rejected">ไม่ผ่าน</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>วันที่สัมภาษณ์ (ถ้ามี)</label>
                    <input type="date" id="interview-date">
                </div>
                <div class="input-group" style="grid-column: 1 / -1; margin-top: 10px;">
                    <label>บันทึกเพิ่มเติม (เช่น รายละเอียดการสัมภาษณ์, ลิงก์ประกาศงาน)</label>
                    <textarea id="job-notes" placeholder="จดบันทึกข้อมูลสำคัญที่นี่..." style="padding: 12px; border: 1.5px solid var(--secondary-color); border-radius: 12px; font-family: 'Prompt'; resize: vertical; min-height: 60px;"></textarea>
                </div>
                <button class="btn-add" onclick="addJob()">เพิ่มรายการ</button>
            </div>
        </div>

        <!-- Search & Filter Section -->
        <div class="search-filter-container">
            <div class="input-group">
                <input type="text" id="search-input" placeholder="🔍 ค้นหาชื่อบริษัทหรือตำแหน่ง..." oninput="renderJobs()">
            </div>
            <div class="input-group">
                <select id="filter-status" onchange="renderJobs()">
                    <option value="all">แสดงทั้งหมด</option>
                    <option value="pending">กำลังเตรียมตัว</option>
                    <option value="applied">ส่งใบสมัครแล้ว</option>
                    <option value="interview">รอสัมภาษณ์</option>
                    <option value="hired">ได้งานแล้ว</option>
                    <option value="rejected">ไม่ผ่าน</option>
                </select>
            </div>
            <div class="input-group">
                <select id="sort-type" onchange="renderJobs()">
                    <option value="default">จัดลำดับ: อัตโนมัติ (นัดหมายก่อน)</option>
                    <option value="date-new">วันที่สมัคร: ใหม่ -> เก่า</option>
                    <option value="date-old">วันที่สมัคร: เก่า -> ใหม่</option>
                </select>
            </div>
        </div>

        <div id="job-list-container" class="job-list"></div>
    </div>

    <script>
        // กู้คืนระบบ localStorage เพื่อให้ข้อมูลไม่หายเมื่อ Refresh หน้าเว็บ
        let jobs = JSON.parse(localStorage.getItem('job_applications')) || [];
        let editingJobId = null;

        function addJob() {
            const company = document.getElementById('company-name').value.trim();
            const role = document.getElementById('job-role').value.trim();
            const appliedDate = document.getElementById('applied-date').value;
            const jobUrl = document.getElementById('job-url').value.trim();
            const workType = document.getElementById('job-work-type').value;
            const location = document.getElementById('job-location').value.trim();
            const channel = document.getElementById('job-channel').value;
            const status = document.getElementById('job-status').value;
            const interviewDate = document.getElementById('interview-date').value;
            const notes = document.getElementById('job-notes').value.trim();

            if (!company || !role) {
                alert("กรุณากรอกข้อมูลให้ครบถ้วน");
                return;
            }

            let hiredTriggered = false;

            // โหมดเพิ่มใหม่เท่านั้น
            const newJob = {
                id: Date.now(),
                company, role, location, channel, status, interviewDate, notes, jobUrl, workType,
                date: appliedDate || new Date().toISOString().split('T')[0]
            };
            if (status === 'hired') {
                hiredTriggered = true;
                newJob.hiredDate = new Date().toLocaleDateString('th-TH');
            }
            newJob.isNew = true;
            jobs.unshift(newJob);
            playDingSound();

            if (hiredTriggered) {
                triggerConfetti();
            }

            saveAndRender();
            
            // ล้างสถานะ isNew หลังจากแอนิเมชันเล่นจบ (เพื่อไม่ให้เล่นซ้ำตอน Refresh หรือ Filter)
            setTimeout(() => {
                jobs = jobs.map(j => ({ ...j, isNew: false }));
                localStorage.setItem('job_applications', JSON.stringify(jobs));
            }, 1000);

            clearForm();
        }

        function duplicateJob(id) {
            const job = jobs.find(j => j.id === id);
            if (!job) return;

            // สร้างข้อมูลใหม่โดยคัดลอกค่าเดิม แต่เปลี่ยน ID และวันที่สมัครเป็นวันนี้
            const newJob = {
                ...job,
                id: Date.now(),
                date: new Date().toISOString().split('T')[0],
                isNew: true, // เพื่อให้แสดงแอนิเมชันป๊อปอัพ
                pinned: false // รายการใหม่จะไม่ปักหมุดโดยอัตโนมัติ
            };
            delete newJob.hiredDate; // ลบวันที่ได้งานออกถ้ามี

            jobs.unshift(newJob);
            playDingSound();
            saveAndRender();
            
            // เคลียร์สถานะ isNew หลังจาก 1 วินาที
            setTimeout(() => {
                jobs = jobs.map(j => (j.id === newJob.id ? { ...j, isNew: false } : j));
                localStorage.setItem('job_applications', JSON.stringify(jobs));
            }, 1000);
        }

        function deleteJob(id) {
            if (confirm('คุณต้องการลบรายการนี้ใช่หรือไม่?')) {
                jobs = jobs.filter(job => job.id !== id);
                saveAndRender();
            }
        }

        function togglePin(id) {
            jobs = jobs.map(job => {
                if (job.id === id) return { ...job, pinned: !job.pinned };
                return job;
            });
            saveAndRender();
        }

        function editJob(id) {
            const job = jobs.find(j => j.id === id);
            if (!job) return;

            // ใส่ค่าลงใน Modal
            document.getElementById('edit-company-name').value = job.company;
            document.getElementById('edit-applied-date').value = job.date || '';
            document.getElementById('edit-job-role').value = job.role;
            document.getElementById('edit-job-url').value = job.jobUrl || '';
            document.getElementById('edit-work-type').value = job.workType || 'On-site';
            document.getElementById('edit-job-location').value = job.location || '';
            document.getElementById('edit-job-channel').value = job.channel || 'Direct';
            document.getElementById('edit-job-status').value = job.status;
            document.getElementById('edit-interview-date').value = job.interviewDate || '';
            document.getElementById('edit-job-notes').value = job.notes || '';

            editingJobId = id;
            document.getElementById('edit-modal').classList.add('active');
            document.body.style.overflow = 'hidden'; // ป้องกันการเลื่อนหน้าจอด้านหลัง
        }

        function closeEditModal() {
            document.getElementById('edit-modal').classList.remove('active');
            document.body.style.overflow = 'auto';
            editingJobId = null;
        }

        function saveEdit() {
            if (!editingJobId) return;

            const company = document.getElementById('edit-company-name').value.trim();
            const role = document.getElementById('edit-job-role').value.trim();
            const appliedDate = document.getElementById('edit-applied-date').value;
            const jobUrl = document.getElementById('edit-job-url').value.trim();
            const workType = document.getElementById('edit-work-type').value;
            const location = document.getElementById('edit-job-location').value.trim();
            const channel = document.getElementById('edit-job-channel').value;
            const status = document.getElementById('edit-job-status').value;
            const interviewDate = document.getElementById('edit-interview-date').value;
            const notes = document.getElementById('edit-job-notes').value.trim();

            if (!company || !role) {
                alert("กรุณากรอกข้อมูลให้ครบถ้วน");
                return;
            }

            let hiredTriggered = false;
            jobs = jobs.map(job => {
                if (job.id === editingJobId) {
                    if (status === 'hired' && job.status !== 'hired') hiredTriggered = true;
                    let updatedJob = { ...job, company, role, location, channel, status, interviewDate, notes, date: appliedDate, jobUrl, workType };
                    if (status === 'hired' && job.status !== 'hired') {
                        updatedJob.hiredDate = new Date().toLocaleDateString('th-TH');
                    } else if (status !== 'hired') {
                        delete updatedJob.hiredDate;
                    }
                    return updatedJob;
                }
                return job;
            });

            if (hiredTriggered) triggerConfetti();
            playDingSound();
            
            saveAndRender();
            closeEditModal();
        }

        function clearAllJobs() {
            if (confirm('คุณแน่ใจหรือไม่ว่าต้องการล้างข้อมูลการสมัครงานทั้งหมด? การกระทำนี้ไม่สามารถย้อนกลับได้')) {
                jobs = [];
                saveAndRender();
            }
        }

        function exportToCSV() {
            if (jobs.length === 0) {
                alert("ไม่มีข้อมูลสำหรับการส่งออก");
                return;
            }
            
            const headers = ["บริษัท", "ตำแหน่ง", "สถานที่", "ช่องทางสมัคร", "สถานะ", "วันที่สมัคร", "วันที่สัมภาษณ์", "โน้ต"];
            const rows = jobs.map(j => [
                j.company,
                j.role,
                j.location || "-",
                j.channel || "-",
                j.status,
                new Date(j.date).toLocaleDateString('th-TH'),
                j.interviewDate || "-",
                `"${j.notes?.replace(/"/g, '""') || ""}"`
            ]);

            const csvContent = "\uFEFF" + [headers, ...rows].map(e => e.join(",")).join("\n");
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = `Job_Applications_${new Date().toLocaleDateString('th-TH')}.csv`;
            link.click();
        }

        function backupToJSON() {
            if (jobs.length === 0) {
                alert("ไม่มีข้อมูลสำหรับการสำรอง");
                return;
            }
            const dataStr = JSON.stringify(jobs, null, 2);
            const blob = new Blob([dataStr], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = `Job_Tracker_Backup_${new Date().toLocaleDateString('th-TH').replace(/\//g, '-')}.json`;
            link.click();
            URL.revokeObjectURL(url);
        }

        function importFromJSON(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const importedJobs = JSON.parse(e.target.result);
                    if (Array.isArray(importedJobs)) {
                        if (confirm('คุณต้องการกู้คืนข้อมูลใช่หรือไม่? ข้อมูลปัจจุบันจะถูกแทนที่ด้วยข้อมูลจากไฟล์นี้')) {
                            jobs = importedJobs;
                            saveAndRender();
                            alert('กู้คืนข้อมูลสำเร็จแล้ว! ✨');
                        }
                    } else { alert('รูปแบบไฟล์ไม่ถูกต้อง'); }
                } catch (err) { alert('เกิดข้อผิดพลาดในการอ่านไฟล์'); }
                event.target.value = '';
            };
            reader.readAsText(file);
        }

        function updateStatus(id, newStatus) {
            let hiredTriggered = false;
            jobs = jobs.map(job => {
                if (job.id === id) {
                    let updatedJob = { ...job, status: newStatus };
                    if (newStatus === 'hired' && job.status !== 'hired') {
                        hiredTriggered = true;
                        updatedJob.hiredDate = new Date().toLocaleDateString('th-TH');
                    } else if (newStatus !== 'hired') {
                        delete updatedJob.hiredDate;
                    }
                    return updatedJob;
                }
                return job;
            });

            if (hiredTriggered) {
                triggerConfetti();
            }
            saveAndRender();
        }

        function setFilter(status) {
            document.getElementById('filter-status').value = status;
            renderJobs();
            window.scrollTo({ top: document.querySelector('.search-filter-container').offsetTop - 100, behavior: 'smooth' });
        }

        function playDingSound() {
            const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();

            oscillator.type = 'sine';
            oscillator.frequency.setValueAtTime(987.77, audioCtx.currentTime); // โน้ต B5 ให้ความรู้สึกสดใส
            oscillator.frequency.exponentialRampToValueAtTime(1318.51, audioCtx.currentTime + 0.1); // ดีดเสียงขึ้นเล็กน้อยให้ดูน่ารัก

            gainNode.gain.setValueAtTime(0, audioCtx.currentTime);
            gainNode.gain.linearRampToValueAtTime(0.2, audioCtx.currentTime + 0.05);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);

            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);

            oscillator.start();
            oscillator.stop(audioCtx.currentTime + 0.4);
        }

        function triggerConfetti() {
            confetti({
                particleCount: 150,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#B5A1E2', '#FFB7B2', '#B3E5FC', '#C8E6C9']
            });
        }

        function clearForm() {
            document.getElementById('company-name').value = '';
            document.getElementById('job-role').value = '';
            document.getElementById('job-location').value = '';
            document.getElementById('job-url').value = '';
            document.getElementById('job-work-type').value = 'On-site';
            document.getElementById('applied-date').valueAsDate = new Date();
            document.getElementById('job-channel').value = 'Direct';
            document.getElementById('interview-date').value = '';
            document.getElementById('job-notes').value = '';
            document.getElementById('search-input').value = '';
            document.getElementById('filter-status').value = 'all';
            // เซ็ตวันที่สมัครเป็นวันนี้
            document.getElementById('applied-date').valueAsDate = new Date();
            editingJobId = null;
            document.querySelector('.btn-add').textContent = 'เพิ่มรายการ';
        }

        function saveAndRender() {
            localStorage.setItem('job_applications', JSON.stringify(jobs));
            updateStats();
            checkUpcomingInterviews();
            renderJobs();
        }

        function updateStats() {
            const counts = { pending: 0, applied: 0, interview: 0, hired: 0, rejected: 0 };
            const total = jobs.length;

            jobs.forEach(job => {
                if (counts.hasOwnProperty(job.status)) counts[job.status]++;
            });

            for (const key in counts) {
                const el = document.getElementById(`count-${key}`);
                if (el) el.textContent = counts[key];
                
                // อัปเดต Progress Bar
                const bar = document.getElementById(`bar-${key}`);
                if (bar) {
                    const percentage = total > 0 ? (counts[key] / total) * 100 : 0;
                    bar.style.width = percentage + '%';
                }
            }
        }

        function checkUpcomingInterviews() {
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            const upcoming = jobs.filter(job => {
                if (!job.interviewDate || job.status === 'hired' || job.status === 'rejected') return false;
                const iDate = new Date(job.interviewDate);
                const diff = Math.ceil((iDate - today) / (1000 * 60 * 60 * 24));
                return diff >= 0 && diff <= 3;
            });

            const alertBox = document.getElementById('interview-alert');
            if (upcoming.length > 0) {
                alertBox.style.display = 'block';
                const list = upcoming.map(j => `<b>${j.company}</b>`).join(', ');
                alertBox.innerHTML = `🔔 คุณมีนัดสัมภาษณ์เร็วๆ นี้ที่: ${list}`;
            } else {
                alertBox.style.display = 'none';
            }

            // Highlight Stat Card if interview is today
            const isToday = jobs.some(j => j.interviewDate && new Date(j.interviewDate).toDateString() === new Date().toDateString());
            const interviewCard = document.querySelector('.stat-card[onclick="setFilter(\'interview\')"]');
            if (interviewCard) 
                isToday ? interviewCard.classList.add('interview-today') : interviewCard.classList.remove('interview-today');
        }

        function renderJobs() {
            const container = document.getElementById('job-list-container');
            const searchTerm = document.getElementById('search-input')?.value.toLowerCase() || '';
            const filterStatus = document.getElementById('filter-status')?.value || 'all';
            const sortType = document.getElementById('sort-type')?.value || 'default';

            container.innerHTML = '';

            const sortedJobs = [...jobs].sort((a, b) => {
                if (!!a.pinned !== !!b.pinned) {
                    return a.pinned ? -1 : 1;
                }

                if (sortType === 'date-new') {
                    return new Date(b.date) - new Date(a.date);
                } else if (sortType === 'date-old') {
                    return new Date(a.date) - new Date(b.date);
                } else {
                    // ลำดับความสำคัญแบบอัตโนมัติ: วันที่สัมภาษณ์ใกล้ที่สุดก่อน
                    if (a.interviewDate && b.interviewDate) {
                        return new Date(a.interviewDate) - new Date(b.interviewDate);
                    }
                    if (a.interviewDate) return -1;
                    if (b.interviewDate) return 1;
                    return new Date(b.date) - new Date(a.date);
                }
            });

            const filteredJobs = sortedJobs.filter(job => {
                const matchesSearch = job.company.toLowerCase().includes(searchTerm) || 
                                      job.role.toLowerCase().includes(searchTerm);
                const matchesStatus = filterStatus === 'all' || job.status === filterStatus;
                return matchesSearch && matchesStatus;
            });

            if (filteredJobs.length === 0 && jobs.length > 0) {
                container.innerHTML = '<p style="text-align:center; color:var(--text-light); padding:40px;">ไม่พบรายการที่ตรงเงื่อนไข 🔍</p>';
                return;
            }

            filteredJobs.forEach(job => {
                const item = document.createElement('div');
                const isInterviewNear = job.interviewDate && 
                    Math.ceil((new Date(job.interviewDate) - new Date().setHours(0,0,0,0)) / (1000 * 60 * 60 * 24)) <= 1;
                
                // ตรวจสอบว่าเป็นรายการใหม่หรือไม่เพื่อใส่ Class แอนิเมชัน
                item.className = `job-item ${job.isNew ? 'job-item-new' : ''} ${isInterviewNear ? 'interview-near' : ''}`;
                item.style.borderLeftColor = `var(--${getStatusColor(job.status)})`;

                const formattedAppliedDate = job.date ? new Date(job.date).toLocaleDateString('th-TH') : 'ไม่ระบุ';
                const workTypeBadge = `<span class="status-badge" style="background:#f0f0f0; font-size:0.7rem;">${job.workType || 'On-site'}</span>`;

                const interviewDisplay = job.interviewDate
                    ? `<br><span style="font-size: 0.85rem; color: var(--accent-color); font-weight: 600;">📅 นัดสัมภาษณ์: ${new Date(job.interviewDate).toLocaleDateString('th-TH')}</span>`
                    : '';

                const hiredDisplay = job.hiredDate && job.status === 'hired'
                    ? `<br><span style="font-size: 0.85rem; color: #4CAF50; font-weight: 600;">✨ วันที่ได้งาน: ${job.hiredDate}</span>`
                    : '';

                const locationDisplay = job.location ? `<br><span style="font-size: 0.85rem; color: var(--text-light);">🏢 ${job.location}</span>` : '';
                
                const getChannelColor = (c) => {
                    const colors = {
                        'LinkedIn': '#0077b5',
                        'JobThai': '#e62129',
                        'JobsDB': '#ff6600',
                        'JobGun': '#2c3e50'
                    };
                    return colors[c] || 'var(--text-light)';
                };

                const channelBadge = job.channel ? 
                    `<span class="status-badge" style="background: ${getChannelColor(job.channel)}; color: white; font-size: 0.7rem; margin-left: 5px;">${job.channel}</span>` : '';

                const linkBtn = job.jobUrl ? 
                    `<a href="${job.jobUrl}" target="_blank" title="ดูประกาศงาน" style="text-decoration:none; margin-right:5px;">🔗</a>` : '';

                const notesDisplay = job.notes 
                    ? `<div class="note-display">📝 <b>Note:</b> ${job.notes}</div>` 
                    : '';

                item.innerHTML = `
                    <div class="job-info">
                        <h3>${job.pinned ? '📌 ' : ''}${job.company} ${channelBadge}</h3>
                        <p>${job.role} ${workTypeBadge} • <small>สมัครเมื่อ: ${formattedAppliedDate}</small>${locationDisplay}${interviewDisplay}${hiredDisplay}</p>
                        ${notesDisplay}
                    </div>
                    <div class="actions">
                        ${linkBtn}
                        <button class="btn-pin ${job.pinned ? 'active' : ''}" onclick="togglePin(${job.id})" title="ปักหมุดที่ชอบ">
                            ${job.pinned ? '📌' : '📍'}
                        </button>
                        <select onchange="updateStatus(${job.id}, this.value)" class="status-badge status-${job.status}">
                            <option value="pending"  ${job.status === 'pending'   ? 'selected' : ''}>กำลังเตรียมตัว</option>
                            <option value="applied"  ${job.status === 'applied'   ? 'selected' : ''}>ส่งใบสมัครแล้ว</option>
                            <option value="interview"${job.status === 'interview' ? 'selected' : ''}>รอสัมภาษณ์</option>
                            <option value="hired"    ${job.status === 'hired'     ? 'selected' : ''}>ได้งานแล้ว</option>
                            <option value="rejected" ${job.status === 'rejected'  ? 'selected' : ''}>ไม่ผ่าน</option>
                        </select>
                        <button class="btn-edit" onclick="duplicateJob(${job.id})" title="ทำสำเนาข้อมูล">📋</button>
                        <button class="btn-edit" onclick="editJob(${job.id})">✎</button>
                        <button class="btn-delete" onclick="deleteJob(${job.id})">✕</button>
                    </div>
                `;
                container.appendChild(item);
            });
        }

        function getStatusColor(status) {
            if (status === 'hired')     return 'success';
            if (status === 'interview') return 'warning';
            if (status === 'rejected')  return 'error';
            if (status === 'applied')   return 'info';
            return 'secondary-color';
        }

        // เซ็ตวันที่เริ่มต้นเป็นวันนี้
        document.getElementById('applied-date').valueAsDate = new Date();

        // โหลดครั้งแรก
        saveAndRender();
    </script>
</body>
</html>
